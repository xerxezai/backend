{
  "name": "xerxez-backend",
  "version": "1.0.0",
  "description": "Django REST API backend for XERXEZ frontend with PostgreSQL",
  "scripts": {
    "setup": "python scripts/setup_backend.py",
    "dev": "python scripts/django_manager.py runserver",
    "migrate": "python scripts/django_manager.py migrate",
    "makemigrations": "python scripts/django_manager.py makemigrations",
    "createsuperuser": "python scripts/django_manager.py createsuperuser",
    "collectstatic": "python scripts/django_manager.py collectstatic",
    "test": "python scripts/django_manager.py test",
    "shell": "python scripts/django_manager.py shell",
    "db:create": "python scripts/db_manager.py create",
    "db:test": "python scripts/db_manager.py test",
    "db:backup": "python scripts/db_manager.py backup",
    "db:info": "python scripts/db_manager.py info",
    "format": "black . && isort .",
    "lint": "flake8 .",
    "docs:build": "mkdocs build",
    "docs:serve": "mkdocs serve"
  },
  "keywords": [
    "django",
    "rest-api",
    "postgresql",
    "xerxez",
    "backend"
  ],
  "author": "XERXEZ Team",
  "license": "MIT"
}